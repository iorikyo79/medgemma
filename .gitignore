# ============================================================
# 대용량 데이터 - 로컬에서 다운로드하여 사용
# ============================================================
.conda/

# HuggingFace에서 다운로드하는 원본 데이터셋 (수백 GB)
datasets/

# HuggingFace에서 다운로드하는 모델 파일 (수 GB)
models/

# 학습 체크포인트 (대용량)
checkpoints/

# ============================================================
# 실행 결과 및 로그 - 재생성 가능
# ============================================================

# 평가 결과 CSV (재실행 시 재생성됨), README.md 제외
outputs/**
!outputs/README.md

# 학습 로그
training.log
*.log

# ============================================================
# 주피터 노트북 임시 파일
# ============================================================

.ipynb_checkpoints/

# ============================================================
# 파이썬 캐시
# ============================================================

__pycache__/
*.py[cod]
*.pyo
